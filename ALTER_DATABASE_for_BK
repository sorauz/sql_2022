USE master;
GO

IF EXISTS (SELECT *
           FROM sys.databases
           WHERE name='BK')
BEGIN

    ALTER DATABASE BK
    SET SINGLE_USER
    WITH ROLLBACK IMMEDIATE;

END
GO

RESTORE DATABASE BK
FROM DISK='D:\Backup\Accounting.bak'
WITH
MOVE 'BK'
TO 'C:\Program Files\Microsoft SQL Server\MSSQL17.SQLEXPRESS\MSSQL\DATA\BK.mdf',

MOVE 'BK_log'
TO 'C:\Program Files\Microsoft SQL Server\MSSQL17.SQLEXPRESS\MSSQL\DATA\BK_log.ldf',

REPLACE,
RECOVERY,
STATS=5;
GO

ALTER DATABASE BK
SET MULTI_USER;
GO
